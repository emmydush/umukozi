NODE_ENV=development
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:8000

# Database Configuration
# For SQLite (default)
DB_TYPE=sqlite

# For PostgreSQL (uncomment below)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=umukozi
# DB_USER=umukozi
# DB_PASSWORD=your-password
